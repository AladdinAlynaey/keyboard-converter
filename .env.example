# General Flask Configurations
FLASK_ENV=development
FLASK_APP=app.py
FLASK_SECRET_KEY=generate-a-secure-random-key-for-sessions

# MongoDB Settings
MONGO_URI=mongodb://localhost:27017/
MONGO_DB=keyboard_converter

# JWT Settings
JWT_SECRET_KEY=generate-a-secure-random-jwt-key
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=7

# SMTP Email Settings (Required for verification & password reset)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-smtp-app-password
SMTP_USE_TLS=True
SMTP_USE_SSL=False
SMTP_SENDER=noreply@smartkeyboardconverter.com

# Optional OpenRouter AI Integration
AI_ENABLED=True
OPENROUTER_API_KEY=your-openrouter-api-key
DEFAULT_AI_MODEL=meta-llama/llama-3-8b-instruct:free

# Google OAuth Settings (Optional)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5454/api/auth/google/callback
